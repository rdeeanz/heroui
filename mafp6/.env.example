# ============================================================================
#  Contoh variabel lingkungan SiMFAS-Pelindo. Salin ke .env lalu sesuaikan.
#  JANGAN commit file .env yang berisi kredensial asli.
# ============================================================================

# --- PostgreSQL ---
POSTGRES_USER=simfas                     # Nama user database.
POSTGRES_PASSWORD=ubah_password_ini      # Password database (WAJIB diganti).
POSTGRES_DB=simfas                       # Nama database.
# URL koneksi yang dipakai Prisma (host "postgres" = nama service di docker-compose).
DATABASE_URL=postgresql://simfas:ubah_password_ini@postgres:5432/simfas?schema=public

# --- Backend ---
PORT=3000                                # Port internal backend.
CORS_ORIGIN=http://localhost:8080        # Origin frontend yang diizinkan (pisah koma untuk banyak).
JWT_SECRET=ganti_dengan_string_acak_panjang   # Kunci penandatangan JWT (WAJIB diganti).
JWT_EXPIRES_IN=1d                        # Masa berlaku token.

# --- AWS S3 (penyimpanan tanda tangan/lampiran & hasil ekspor) ---
# Bila BUCKET + ACCESS_KEY + SECRET_KEY diisi, tanda tangan diunggah ke S3.
# Bila dikosongkan, tanda tangan disimpan inline (data URL) di database (default).
S3_REGION=ap-southeast-1                 # Region bucket S3.
S3_BUCKET=                               # Nama bucket (kosongkan untuk mode inline).
S3_ACCESS_KEY_ID=                        # Access key IAM.
S3_SECRET_ACCESS_KEY=                    # Secret key IAM.
S3_ENDPOINT=                             # Kosongkan untuk AWS; isi bila pakai S3-compatible (MinIO).

# --- Email (notifikasi/reminder) ---
# Default: email hanya DICATAT ke log (LogEmailSender). Untuk mengirim email
# sungguhan, implementasikan transport SMTP/SES dan isi variabel di bawah.
SMTP_HOST=                               # Host SMTP (kosongkan untuk mode log).
SMTP_PORT=587                            # Port SMTP.
SMTP_USER=                               # Kredensial SMTP.
SMTP_PASSWORD=                           # Kredensial SMTP.
SMTP_FROM=no-reply@pelindo.co.id         # Alamat pengirim.

# --- Frontend (dibaca saat build Vite) ---
VITE_API_BASE_URL=/api                   # Base URL API (relatif, di-proxy Nginx).
